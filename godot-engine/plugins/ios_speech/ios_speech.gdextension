[configuration]

is_library_extension=true
entry_symbol="ios_speech_gdextension_entry"

[dependencies]

custom_library="res://plugins/ios_speech/bin/ios_speech.extension"

[options]

supports_editor=false
toolkit=false

[permissions]

com.apple.security.app-sandbox=false

[ios]

speech_recognition=true
microphone_usage=true
