{
  "cloud": {
    "provider": "openai",
    "api_key": "YOUR_API_KEY_HERE",
    "model": "gpt-4",
    "endpoint": "https://api.openai.com/v1/chat/completions"
  },
  "local": {
    "model_path": "res://assets/models/dialogue_model.onnx",
    "enabled": true,
    "model_type": "phi-3-mini"
  },
  "settings": {
    "timeout_seconds": 30,
    "max_retries": 3,
    "cache_enabled": true
  }
}
